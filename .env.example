# ─── Intelli-Credit Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is git-ignored. Never commit real API keys.

# ── LLM API ───────────────────────────────────────────────────────────────────
# Required for CAM narrative generation (Step 7).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App Settings ──────────────────────────────────────────────────────────────
INTELLI_DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (zero config). Change to PostgreSQL URL for production.
# INTELLI_DATABASE_URL=postgresql+asyncpg://user:pass@localhost/intellicredit

# ── Research Agent ────────────────────────────────────────────────────────────
# Set to true to always use pre-cached results (recommended for demo).
INTELLI_USE_CACHED_RESEARCH=true

# ── Rate Settings (update at demo time) ───────────────────────────────────────
INTELLI_RBI_REPO_RATE=6.50